# Copier en `.env` et renseigner les valeurs de VOTRE projet Supabase.
# Seules les variables préfixées PUBLIC_ sont exposées au navigateur (Astro).
# Clé "publishable" (anon) uniquement — jamais la clé secrète ni le mot de passe DB.
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
