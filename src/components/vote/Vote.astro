---
import type { Lang } from '@/i18n';
import { useTranslations } from '@/i18n';
import VoteGrid from './VoteGrid';
import Dashboard from './Dashboard';

interface Props {
  lang: Lang;
  /** Affiche le tableau de bord de convergence (par défaut : oui). */
  showDashboard?: boolean;
}
const { lang, showDashboard = true } = Astro.props;
const t = useTranslations(lang);
---

<section id="disponibilites" class="bg-gradient-to-b from-paper to-[#EAF0F7] py-24 sm:py-28">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="reveal mb-10 max-w-2xl">
      <p class="mb-4 font-mono text-xs uppercase tracking-[0.18em] text-teal-600">{t.vote.eyebrow}</p>
      <h2
        class="font-display text-[clamp(2rem,5vw,3.4rem)] font-light leading-[1.05] tracking-[-0.01em] text-ink-900"
      >
        {t.vote.heading}
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-ink-500">{t.vote.lead}</p>
    </div>

    <div class="reveal">
      <VoteGrid lang={lang} t={t.vote} client:visible />
    </div>

    {
      showDashboard && (
        <div class="reveal mt-14">
          <div class="mb-6 max-w-2xl">
            <p class="mb-3 font-mono text-xs uppercase tracking-[0.18em] text-teal-600">
              {t.dashboard.eyebrow}
            </p>
            <h3 class="font-display text-2xl font-light text-ink-900 sm:text-3xl">
              {t.dashboard.heading}
            </h3>
            <p class="mt-3 leading-relaxed text-ink-500">{t.dashboard.lead}</p>
          </div>
          <Dashboard lang={lang} t={t.dashboard} client:visible />
        </div>
      )
    }
  </div>
</section>
