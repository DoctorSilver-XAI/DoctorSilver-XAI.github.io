---
import type { Lang } from '@/i18n';
import { useTranslations } from '@/i18n';
import Nav from '@/components/nav/Nav.astro';
import JourJ from '@/components/jourj/JourJ.astro';
import InsightsSection from '@/components/insights/InsightsSection.astro';
import Footer from '@/components/footer/Footer.astro';

interface Props {
  lang: Lang;
  path?: string;
}
const { lang, path = '/jury' } = Astro.props;
const t = useTranslations(lang);
---

<Nav lang={lang} path={path} />
<main id="contenu" class="bg-gradient-to-b from-paper to-[#EAF0F7] pt-16">
  <!-- h1 de la page (les sections n'exposent que des h2) : masqué visuellement, lu par les AT. -->
  <h1 class="sr-only">{t.insights.headingJury}</h1>
  <JourJ lang={lang} />
  <InsightsSection lang={lang} mode="jury" />
</main>
<Footer lang={lang} />
