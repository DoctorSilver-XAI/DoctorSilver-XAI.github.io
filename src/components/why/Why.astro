---
import type { Lang } from '@/i18n';
import { useTranslations } from '@/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const cards = [
  {
    body: t.why.c1,
    accent: 'bg-clinical-600/10 text-clinical-600',
    icon: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  },
  {
    body: t.why.c2,
    accent: 'bg-teal-500/10 text-teal-600',
    icon: '<path d="M5 8h14M5 8a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2M5 8v9a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8M9 12h6"/>',
  },
  {
    body: t.why.c3,
    accent: 'bg-neuro-500/10 text-neuro-500',
    icon: '<path d="M12 3a4 4 0 0 0-4 4 3.5 3.5 0 0 0-1 6.8A3.5 3.5 0 0 0 12 19a3.5 3.5 0 0 0 5-5.2A3.5 3.5 0 0 0 16 7a4 4 0 0 0-4-4Z"/><path d="M12 3v16"/>',
  },
];
---

<section id="pourquoi-venir" class="dotgrid bg-paper py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6 sm:px-8">
    <div class="reveal mb-14 max-w-2xl">
      <p class="mb-4 font-mono text-xs uppercase tracking-[0.18em] text-teal-600">{t.why.eyebrow}</p>
      <h2
        class="font-display text-[clamp(2rem,5vw,3.4rem)] font-light leading-[1.05] tracking-[-0.01em] text-ink-900"
      >
        {t.why.heading}
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-ink-500">{t.why.lead}</p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {
        cards.map((card, i) => (
          <article class="glass-card reveal p-7 sm:p-8" style={`transition-delay:${0.05 + i * 0.08}s`}>
            <div class={`mb-5 grid h-11 w-11 place-items-center rounded-xl ${card.accent}`}>
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                aria-hidden="true"
                set:html={card.icon}
              />
            </div>
            <h3 class="mb-2.5 font-display text-xl text-ink-900">{card.body.title}</h3>
            {/* set:html requis pour les <em> du texte i18n. Source 100% statique/interne :
                ne JAMAIS y brancher de donnée dynamique ou externe (sinon risque XSS). */}
            <p class="text-[0.96rem] leading-relaxed text-ink-500" set:html={card.body.body} />
            <p class="mt-4 font-mono text-[0.68rem] uppercase tracking-wider text-teal-600/80">
              {card.body.tag}
            </p>
          </article>
        ))
      }
    </div>

    <!-- Schéma translationnel : du médicament au dispositif numérique -->
    <div class="reveal relative mt-14 py-6" aria-hidden="true">
      <span
        class="absolute left-0 right-0 top-1/2 h-px bg-gradient-to-r from-clinical-400 via-teal-500 to-neuro-500 opacity-50"
      ></span>
      <div class="relative flex items-center justify-between gap-2 font-mono text-[0.7rem] text-ink-500 sm:text-xs">
        <span class="rounded-full border border-line bg-paper px-3 py-1">{t.why.trans.a}</span>
        <span class="rounded-full border border-line bg-paper px-3 py-1">{t.why.trans.b}</span>
        <span class="rounded-full border border-line bg-paper px-3 py-1">{t.why.trans.c}</span>
        <span class="rounded-full border border-teal-500/40 bg-paper px-3 py-1 text-teal-700">
          {t.why.trans.d}
        </span>
      </div>
    </div>
  </div>
</section>
