---
import type { Lang } from '@/i18n';
import { useTranslations } from '@/i18n';
import { getCollection, render } from 'astro:content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// Paliers du scrollytelling pour la langue courante, triés par ordre.
const entries = (await getCollection('scrollytelling', (e) => e.data.lang === lang)).sort(
  (a, b) => a.data.order - b.data.order,
);
const steps = await Promise.all(
  entries.map(async (e) => ({ data: e.data, Content: (await render(e)).Content })),
);
---

<section id="le-sujet" class="bg-paper py-24 sm:py-32">
  <div class="mx-auto max-w-5xl px-6 sm:px-8">
    <div class="reveal mb-16 max-w-2xl">
      <p class="mb-4 font-mono text-xs uppercase tracking-[0.18em] text-teal-600">
        {t.story.eyebrow}
      </p>
      <h2
        class="font-display text-[clamp(2rem,5vw,3.4rem)] font-light leading-[1.05] tracking-[-0.01em] text-ink-900"
      >
        {t.story.heading}
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-ink-500">{t.story.lead}</p>
    </div>

    <ol class="relative space-y-12 sm:space-y-16">
      <!-- Fil translationnel reliant les paliers -->
      <span
        class="absolute bottom-2 left-[18px] top-2 w-px bg-gradient-to-b from-clinical-400/40 via-teal-500/40 to-neuro-500/40 sm:left-[22px]"
        aria-hidden="true"></span>

      {
        steps.map(({ data, Content }) => (
          <li class="reveal relative pl-14 sm:pl-20">
            <span class="absolute left-0 top-0 grid h-9 w-9 place-items-center rounded-xl border border-line bg-white font-mono text-sm text-clinical-600 shadow-sm sm:h-11 sm:w-11">
              {String(data.order).padStart(2, '0')}
            </span>
            <p class="mb-2 font-mono text-xs uppercase tracking-[0.16em] text-teal-600">
              {data.eyebrow}
            </p>
            <h3 class="font-display text-2xl text-ink-900 sm:text-3xl">{data.title}</h3>
            <p class="mt-3 max-w-2xl text-lg leading-relaxed text-ink-700">{data.summary}</p>
            <details class="group mt-4 max-w-2xl rounded-xl border border-line bg-white/70 px-4">
              <summary class="flex cursor-pointer list-none items-center gap-2 py-3 font-medium text-clinical-600 [&::-webkit-details-marker]:hidden">
                <svg
                  class="h-4 w-4 transition-transform group-open:rotate-90"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M9 6l6 6-6 6" />
                </svg>
                {data.deepDiveTitle ?? t.story.deepDive}
              </summary>
              <div class="deepdive pb-4 pt-1">
                <Content />
              </div>
            </details>
          </li>
        ))
      }
    </ol>

    <p class="reveal mt-16 font-display text-xl italic text-ink-400">{t.story.close}</p>
  </div>
</section>
